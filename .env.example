# ── Supabase (OBLIGATORIO) ──────────────────────────────────
# Reemplaza con las credenciales de tu proyecto Supabase
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=tu-clave-anonima-aqui
VITE_SUPABASE_PROJECT_ID=tu-project-id

# ── Lovable AI Gateway (para analyze-report-image) ──────────
# LOVABLE_API_KEY=tu_api_key

# ── Cloudinary (para cloudinary-upload) ─────────────────────
# CLOUDINARY_CLOUD_NAME=tu_cloud_name
# CLOUDINARY_API_KEY=tu_api_key
# CLOUDINARY_API_SECRET=tu_api_secret

# ── Supabase Service Role (para cleanup-user-locations) ─────
# SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key
